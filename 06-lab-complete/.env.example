# Copy thành .env.local và điền giá trị thật
# ❌ KHÔNG commit file .env.local lên Git

# Server
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development
DEBUG=true

# App
APP_NAME=AI Agent
APP_VERSION=1.0.0

# LLM — BaSau agent (Day06 Hackathon) uses Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_TEMPERATURE=0.3
GEMINI_MAX_OUTPUT_TOKENS=512

# Fallback mock (used when GEMINI_API_KEY is empty)
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini

# Data paths (defaults work inside Docker)
# DATA_JSON_PATH=/app/data/data.json
# SYSTEM_PROMPT_PATH=/app/ai-model/SYSTEM_PROMPT.md

# Security — BẮT BUỘC thay trong production
AGENT_API_KEY=dev-key-change-me-in-production
JWT_SECRET=dev-jwt-secret-change-in-production

# Rate & Budget
RATE_LIMIT_PER_MINUTE=20
DAILY_BUDGET_USD=5.0

# Storage
REDIS_URL=redis://localhost:6379/0

# CORS
ALLOWED_ORIGINS=http://localhost:3000
